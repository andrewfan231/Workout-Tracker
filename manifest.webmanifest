{
  "name": "Andrew's Workout Tracker",
  "short_name": "Workout XP",
  "description": "A game-style workout tracker for logging training, goals, XP, rewards, and progression.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "background_color": "#06162f",
  "theme_color": "#2f80ff",
  "orientation": "portrait-primary",
