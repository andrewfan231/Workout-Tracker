    {
      "src": "/app-icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Workout",
      "short_name": "Workout",
      "url": "/workout.html#log",
      "description": "Jump straight into logging a workout."
    },
    {
      "name": "Spend XP",
      "short_name": "Shop",
      "url": "/shop.html",
      "description": "Open the reward shop."
    }
  ]
}
